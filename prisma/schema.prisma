// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TypeProjet {
  TM
  FORFAIT
}

enum Phase {
  BUILD
  RUN
  MIXTE
}

enum StatutGlobal {
  CRITIQUE
  WARNING
  SOUS_CONTROLE
  OK
}

enum RelationClient {
  DEGRADEE
  TENDUE
  SAINE
}

enum MeteoEquipe {
  DESENGAGEMENT
  FRAGILE
  ENGAGEE
}

enum StatutPlan {
  NON_LANCE
  EN_COURS
  PREMIERS_RESULTATS
  INEFFICACE
}

enum IaUtilisee {
  OUI
  EN_COURS
  NON
}

enum GainIa {
  ZERO
  MOINS_5
  CINQ_DIX
  DIX_VINGT
  PLUS_20
}

enum FreinIa {
  MANQUE_TEMPS
  MANQUE_COMPETENCES
  CONTRAINTES_CLIENT
  SECURITE_CONFIDENTIALITE
  OUTILS_NON_DISPONIBLES
  AUCUN
  AUTRE
}

enum FicheStatut {
  A_COMPLETER
  SOUMISE
}

// Un projet suivi dans la durée. Sert d'ancre pour l'historisation mensuelle
// des fiches et pour savoir à qui envoyer le rappel de clôture.
model Projet {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nom                  String
  client               String
  responsablePilotage  String
  responsableEmail     String
  typeProjet           TypeProjet

  fiches Fiche[]

  @@unique([nom, client])
}

model Fiche {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dateMiseAJour DateTime

  // Rattachement au projet + période couverte (clôture mensuelle).
  // Une seule fiche par projet et par mois.
  projetId      String
  dossierProjet Projet      @relation(fields: [projetId], references: [id], onDelete: Cascade)
  periode       DateTime
  statut        FicheStatut @default(SOUMISE)
  notifieLe     DateTime?

  // A. Informations générales
  projet              String
  client              String
  responsablePilotage String
  responsableEmail    String     @default("")
  typeProjet          TypeProjet
  phaseActuelle       Phase

  // B. Indicateurs visuels clés
  statutGlobal              StatutGlobal
  relationClient            RelationClient
  relationClientCommentaire String?
  meteoEquipe               MeteoEquipe
  signauxFaibles            String?
  departsCles               String?

  // C. Compréhension rapide de la dérive
  causes Json

  difficultesMaitrisables    String?
  difficultesNonMaitrisables String?

  ecartMargePct              Float?
  ecartMargeCommentaire      String?
  ecartPlanningJours         Float?
  ecartPlanningCommentaire   String?
  chargeReevalueePct         Float?
  chargeReevalueeCommentaire String?
  avancementPct              Float?
  avancementCommentaire      String?

  // D. Plan d'action & trajectoire
  planRemediationDefini Boolean
  statutPlan            StatutPlan?
  actions               Json
  risques               Json
  besoinsSupport        Json

  // E. Intelligence Artificielle
  iaUtilisee           IaUtilisee @default(NON)
  iaPhases             Json       @default("{}")
  iaGainEstime         GainIa     @default(ZERO)
  iaCasUsagePrincipal  String?
  iaFrein              FreinIa    @default(AUCUN)
  iaFreinCommentaire   String?

  @@unique([projetId, periode])
  @@index([projet])
  @@index([dateMiseAJour])
  @@index([statut])
}
