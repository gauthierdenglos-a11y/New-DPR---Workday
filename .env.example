DATABASE_URL="postgresql://fiche_flash:fiche_flash@localhost:5432/fiche_flash?schema=public"

# URL publique de l'application, utilisée dans le lien envoyé par email
APP_BASE_URL="http://localhost:3000"

# Jeton partagé pour déclencher la clôture mensuelle (POST/GET /api/cron/cloture-mensuelle
# avec le header "Authorization: Bearer <CRON_SECRET>"). À demander/générer côté DSI.
CRON_SECRET=""

# SMTP fourni par la DSI pour l'envoi des notifications de clôture.
# Tant qu'il n'est pas configuré, les fiches du mois sont bien générées mais
# aucun email n'est envoyé (voir lib/email.ts).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@fiche-flash-projet.local"
